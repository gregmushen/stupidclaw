# =============================================================================
# StupidClaw Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- API Keys ---
# GRE workspace key (same as LINEAR_KEY_GREG)
LINEAR_API_KEY=lin_api_REPLACE_ME

# Claude API key
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Linear STU Team ---
# Team UUID — run setup_workspace.py after creating the STU team to get this
LINEAR_TEAM_ID=REPLACE_ME
# Workspace slug used in links (e.g. https://linear.app/<slug>/issue/STU-123)
LINEAR_WORKSPACE_SLUG=stupidclaw

# State IDs (populated by setup_workspace.py)
STATE_BACKLOG=REPLACE_ME
STATE_TODO=REPLACE_ME
STATE_TRIAGED=REPLACE_ME
STATE_PLANNING_COMPLETE=REPLACE_ME
STATE_IN_PROGRESS=REPLACE_ME
STATE_IN_REVIEW=REPLACE_ME
STATE_BLOCKED=REPLACE_ME
STATE_DONE=REPLACE_ME
STATE_CANCELLED=REPLACE_ME

# Label IDs (populated by setup_workspace.py)
LABEL_AGENT_TASK=REPLACE_ME
LABEL_HUMAN_TASK=REPLACE_ME
LABEL_CLARIFICATION=REPLACE_ME
LABEL_SCOPE_CHANGE=REPLACE_ME
LABEL_ERROR=REPLACE_ME
LABEL_TYPE_RESEARCH=REPLACE_ME
LABEL_TYPE_PURCHASE=REPLACE_ME
LABEL_TYPE_MAINTENANCE=REPLACE_ME
LABEL_TYPE_ADMIN=REPLACE_ME
LABEL_TYPE_SOFTWARE=REPLACE_ME

# --- Cost Controls ---
# Daily budget cap in USD (resets at midnight UTC)
DAILY_BUDGET_CAP=5.00

# Max input + output tokens per parent issue
PER_TASK_TOKEN_CAP=100000

# Path to cost tracker JSON (inside container)
COST_TRACKER_PATH=/var/data/stupidclaw/cost_tracker.json

# --- Model ---
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Logging ---
LOG_LEVEL=INFO
LOG_PATH=/var/log/stupidclaw/pipeline.log

# --- Pipeline ---
# Path to lockfile (prevents concurrent runs)
LOCKFILE_PATH=/tmp/stupidclaw.lock

# Hours before posting a nudge comment on blocked issues
STALE_BLOCKED_HOURS=48

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # From @BotFather — format: 123456789:ABCDEF...
TELEGRAM_CHAT_ID=           # Your personal Telegram chat ID (integer)
TELEGRAM_NOTIFY_PORT=8080   # Port the bot's HTTP server listens on
TELEGRAM_NOTIFY_HOST_PORT=38080  # Host port mapped to telegram-bot:8080 (for Cloudflare tunnel)
TELEGRAM_BOT_URL=http://telegram-bot:8080  # Used by pipeline to POST notifications
